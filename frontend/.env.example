# Publish default: Wasm-only (no backend fallback)
VITE_ENABLE_BACKEND_FALLBACK=false

# Sentry DSN (get from sentry.io)
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.us.sentry.io/xxxx

# Optional explicit release label for Sentry aggregation
# VITE_SENTRY_RELEASE=vrm2pmx-web@1.0

# Optional: Slack Incoming Webhook URL for heart feedback
# VITE_HEART_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Optional: Google Apps Script Web App URL for heart feedback archive
# If set, heart feedback will be posted to GAS in addition to Slack
# VITE_HEART_GAS_WEB_APP_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxx/exec
