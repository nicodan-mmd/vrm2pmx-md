# Publish default: Wasm-only (no backend fallback)
VITE_ENABLE_BACKEND_FALLBACK=false

# Sentry DSN (get from sentry.io)
# VITE_SENTRY_DSN=https://xxxx@xxxx.ingest.us.sentry.io/xxxx

# Optional explicit release label for Sentry aggregation
# VITE_SENTRY_RELEASE=vrm2pmx-web@1.0

# Optional: Slack Incoming Webhook URL for heart feedback
# VITE_HEART_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Optional: Google Apps Script Web App URL for heart feedback archive
# If set, heart feedback will be posted to GAS in addition to Slack
# VITE_HEART_GAS_WEB_APP_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxx/exec

# Firebase / Firestore (World Counter)
# Set these in frontend/.env.local (gitignored), not in source code.
# VITE_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
# VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890abcdef
# Optional
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# Firebase App Check (reCAPTCHA v3 site key)
# VITE_FIREBASE_APPCHECK_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Local-only App Check debug token. Set to true once to print a token in the console,
# then register that token in Firebase Console > App Check > Manage debug tokens.
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=true
